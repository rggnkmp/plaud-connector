{
  "name": "plaud-connector",
  "private": true,
  "description": "Fork: unofficial Plaud API toolkit (CLI, core, MCP). Maintainer: rggnkmp. Upstream: sergivalverde/plaud.",
  "author": "rggnkmp (https://github.com/rggnkmp)",
  "repository": {
    "type": "git",
    "url": "https://github.com/rggnkmp/plaud-connector.git"
  },
  "bugs": {
    "url": "https://github.com/rggnkmp/plaud-connector/issues"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "postinstall": "node scripts/write-cursor-mcp.mjs",
    "test": "vitest run",
    "test:integration": "PLAUD_INTEGRATION=1 vitest run packages/core/test/integration.test.ts",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.json",
    "mcp": "tsx packages/mcp/src/index.ts",
    "login": "tsx packages/cli/bin/plaud.ts login",
    "login-oauth": "tsx packages/cli/bin/plaud.ts login-oauth",
    "import-token": "tsx packages/cli/bin/plaud.ts import-token",
    "used-templates": "tsx packages/cli/bin/plaud.ts used-templates",
    "setup-cursor": "node scripts/write-cursor-mcp.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0",
    "tsx": "^4.7.0"
  },
  "overrides": {
    "zod": "^4.3.6"
  }
}
